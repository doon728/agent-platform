# Agent Runtime Shell — Container 1
# Deployed per agent, per customer.

# Points Container 1 at Container 2 — the only config needed to switch deployment mode.
#
# Local dev:        PLATFORM_SERVICES_URL=http://localhost:8002
# Same VPC:         PLATFORM_SERVICES_URL=http://platform-services:8080
# Cross-VPC:        PLATFORM_SERVICES_URL=https://platform-services.yourvpc.com
PLATFORM_SERVICES_URL=http://localhost:8002

# Agent identity
AGENT_TYPE=chat_agent
ACTIVE_USECASE=chat_agent
CAPABILITY_NAME=care-management
USECASE_NAME=pre-call-assessment
ENVIRONMENT=local

# HITL approval store (local SQLite in Container 1)
HITL_DB_PATH=/app/state/hitl/approvals.db

# Auth
AUTH_MODE=dev
