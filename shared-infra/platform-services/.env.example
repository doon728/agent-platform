# Platform Services — Container 2
# Deployed once per customer, shared across all their agents.

# LLM
OPENAI_API_KEY=your-key-here
OPENAI_MODEL=gpt-4o-mini

# Tool Gateway — Container 3
TOOL_GATEWAY_URL=http://tool-gateway:8080

# Agent config path (where agent.yaml / memory.yaml / rag.yaml etc. are mounted)
AGENT_CONFIG_PATH=/app/config

# Active agent type (read by usecase_config_loader)
AGENT_TYPE=chat_agent
ACTIVE_USECASE=chat_agent
CAPABILITY_NAME=care-management
USECASE_NAME=pre-call-assessment
ENVIRONMENT=production

# Memory backend
MEMORY_BACKEND=file
MEMORY_BASE_PATH=/app/state/memory

# Observability
LOG_LEVEL=INFO
